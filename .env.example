STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
DATABASE_URL=
REDIS_URL=
CLOUDFLARE_R2_ACCESS_KEY=...
CLOUDFLARE_R2_SECRET_KEY=...
# REQUIRED: 32+ byte random secret. NEVER copy this example value verbatim.
# Generate one with: openssl rand -base64 48
# Session JWTs, the CSRF HMAC, and (when ENTERPRISE_SSO_SECRET is unset) the SSO
# fallback all key off this single secret, so a weak/shared value allows full JWT forgery.
JWT_SECRET=
# REQUIRED: 32+ byte random secret used only to HMAC-hash issued user API keys
# before storage. Generate one with: openssl rand -base64 48
STYX_API_KEY_PEPPER=
# REQUIRED for enterprise SSO. Dedicated key the external corporate IdP signs SSO
# assertions with. If UNSET, /auth/enterprise is rejected outright (the service no
# longer falls back to verifying assertions with JWT_SECRET). Use a distinct
# 32+ byte random secret, e.g. openssl rand -base64 48
ENTERPRISE_SSO_SECRET=
GEMINI_API_KEY=

# Chat LLM (Groq free tier — get key at console.groq.com)
GROQ_API_KEY=gsk_...
# Optional: override provider/model for any OpenAI-compatible endpoint
LLM_BASE_URL=
LLM_MODEL=llama-3.3-70b-versatile
R2_ENDPOINT=
R2_ACCOUNT_ID=
R2_BUCKET=styx-proofs
SALESFORCE_BASE_URL=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
HUBSPOT_API_KEY=
ANONYMIZATION_SALT=

# Transactional email. If SENDGRID_API_KEY or a verified sender is absent, the API
# falls back to the mock sender and logs the queued email.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_EARLY_ACCESS_ONBOARDING_TEMPLATE_ID=
STYX_EMAIL_FROM=

# Beta / release metadata (Phase 1 mobile-first private beta defaults)
STYX_ENV_LABEL=local
STYX_PRIVATE_BETA=true
STYX_TEST_MONEY_MODE=true
STYX_ALLOWLIST_US_ONLY=true
STYX_MAINTENANCE_MODE=false
STYX_PHASE1_MOBILE_PRIMARY=true
STYX_PHASE1_NO_CONTACT_ONLY=true
STYX_FEATURE_B2B_HR_UI=false
STYX_MOBILE_MIN_IOS_VERSION=1.0.0-beta.1
STYX_MOBILE_MIN_IOS_BUILD=1

# Runtime URLs and ports
API_PORT=
STYX_WEB_PORT=
STYX_API_PUBLIC_URL=
STYX_WEB_PUBLIC_URL=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WEB_URL=
NEXT_PUBLIC_STYX_ENV_LABEL=local
NEXT_PUBLIC_STYX_PRIVATE_BETA=true
NEXT_PUBLIC_STYX_TEST_MONEY_MODE=true
NEXT_PUBLIC_STYX_FEATURE_B2B_HR_UI=false
EXPO_PUBLIC_STYX_MOBILE_VERSION=1.0.0-beta.1
EXPO_PUBLIC_STYX_MOBILE_BUILD=1

# ============================================================================
# Required secrets (NO insecure runtime fallback — services throw if unset)
# ============================================================================
# These previously defaulted to hardcoded dev values; the fallbacks were
# removed for security, so they must be set in every environment.
# JWT_SECRET is already declared above.
# STYX_API_KEY_PEPPER is already declared above.
APP_SECRET=                 # Social-layer alias HMAC key
ANONYMIZE_SALT=             # B2B export pseudonymization salt (code reads ANONYMIZE_SALT)
ZK_EXHAUST_SECRET=          # zk-exhaust verifier HMAC key
STYX_WEBHOOK_SECRET=        # B2B outbound webhook HMAC signing secret
INTERNAL_SERVICE_TOKEN=     # Shared token for internal service-to-service calls (proof processing-complete)
STYX_DATA_LAKE_EXPORT_DIR=  # Export destination for sanitized data-lake extracts

# Docker/local compose wiring. Set these per environment before using
# .config/docker/docker-compose.yml.
STYX_DOCKER_API_PORT=
STYX_DOCKER_WEB_PORT=
STYX_DOCKER_POSTGRES_PORT=
STYX_DOCKER_REDIS_PORT=
STYX_DOCKER_API_CONTAINER_PORT=
STYX_DOCKER_WEB_CONTAINER_PORT=
STYX_DOCKER_API_NODE_ENV=
STYX_DOCKER_WEB_NODE_ENV=
STYX_DOCKER_POSTGRES_IMAGE=
STYX_DOCKER_REDIS_IMAGE=
STYX_DOCKER_API_INTERNAL_URL=
STYX_DOCKER_DATABASE_URL=
STYX_DOCKER_REDIS_URL=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=
REDIS_PORT=

# Ngrok tunnel config (for .config/ngrok/ngrok_app.yml)
NGROK_AUTHTOKEN=
STYX_NGROK_API_ADDR=
STYX_NGROK_API_HOST_HEADER=
STYX_NGROK_WEB_ADDR=
STYX_NGROK_WEB_HOST_HEADER=

# Compliance / Geofence Controls
# KYC fails CLOSED in production: it is ENFORCED by default there and only disabled
# by an explicit KYC_ENFORCEMENT_ENABLED=false. Outside production it is opt-in
# (default off) so local/dev/test flows are not blocked. Set to 'true' to enforce here.
KYC_ENFORCEMENT_ENABLED=false
# Fail-closed by default (Phase Beta P0-004). Set to 'true' for local dev without geo headers.
GEOFENCE_FAIL_OPEN_ON_MISSING_HEADERS=false
# Optional explicit override for missing-location behavior (allow|open|true to fail open).
GEO_MISSING_HEADER_ACTION=
# Only trust cf-ipstate / x-forwarded-for / cf-connecting-ip / x-real-ip when behind a
# trusted proxy/CloudFlare. Default off — geo resolves from the socket address otherwise.
TRUST_PROXY_HEADERS=false
STYX_IDENTITY_PROVIDER=mock
STRIPE_IDENTITY_WEBHOOK_SECRET=

# Error Monitoring (optional — get DSN from your monitoring provider)
SENTRY_DSN=

# ============================================================================
# Project Identity (authority for brand binding)
# ============================================================================
# These declare the canonical source of truth for the project's identity.
# Currently, the same values are also duplicated across other files (Info.plist,
# build.gradle, render.yaml, package.json, docker-compose.yml, ngrok yaml, legal
# docs, outreach docs). Each duplication is a drift risk. The structural fix —
# build-time templating from .env → each propagation target — is unimplemented;
# tracked as an IRF candidate. Until that lands, when you change a value here,
# also update every propagation target. The full propagation map and migration
# plan live in:
#   docs/planning/planning--styx-sequence-b-a-c--canonical-domain-standup--2026-05-17.md
CANONICAL_DOMAIN=
PROJECT_NAME=
MOBILE_BUNDLE_ID=
DEEP_LINK_SCHEME=
CONTACT_EMAIL_DOMAIN=
RENDER_API_SERVICE_NAME=
RENDER_WEB_SERVICE_NAME=
# NOTE: README.md:5 badge cites organvm-iii-ergon/ namespace; git remote is
# a-organvm/. Divergence surfaced 2026-05-17 by env-var consolidation. The
# git remote is authoritative (it determines where pushes go). The README
# badge is stale and should be migrated. Until then: the value below matches
# the git remote.
CANONICAL_REPO_URL=
