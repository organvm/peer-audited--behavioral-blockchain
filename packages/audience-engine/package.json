    "vitest": "^4.1.0"
  },
  "keywords": [
    "audience-growth",
    "content-engine",
    "playbook",
    "parameterized",
    "styx"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  }
