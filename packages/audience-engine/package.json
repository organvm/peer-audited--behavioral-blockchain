{
  "name": "@styx/audience-engine",
  "version": "0.1.0",
  "description": "Portable Audience Growth Engine CLI — parameterized 5-parameter engine that generates 30-day content plans for any forward-facing product. Extracted from docs/playbooks/playbook--audience-growth-engine.md.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "audience-engine": "dist/cli.js"
  },
  "files": [
